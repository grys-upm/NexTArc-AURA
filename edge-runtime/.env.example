# ==============================================================================
# AURA Edge Runtime — Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' in the same directory to customize the edge runtime:
#   cp .env.example .env
# ==============================================================================

# ── Device Identification ─────────────────────────────────────────────────────
# Unique identifier of this edge device in the AURA platform
AURA_DEVICE_ID=a7b02342-4d3e-412a-b821-81194fc46f7a

# ── Hardware & Peripherals ────────────────────────────────────────────────────
# Hardware accelerator type: rpi (CPU only), hailo8, hailo8l, or rpi_ai_cam
AURA_HARDWARE_TYPE=rpi_ai_cam

# Active peripheral IDs to enable (comma-separated or JSON list)
# Available in config/components_config.yaml: camera_0, env_sensor_0
AURA_PERIPHERALS=camera_0,gps_0

# GPS Coordinates of the device [longitude, latitude]
AURA_COORDINATES="[-3.6294, 40.3897]"

# ── Connection & Networking ───────────────────────────────────────────────────
# IP or hostname of the AURA Mosquitto MQTT Broker (access from container)
# (If running standalone on the host, set this to the Host IP or localhost)
AURA_MQTT_HOST=aura-mosquitto

# Port of the AURA Mosquitto MQTT Broker
AURA_MQTT_PORT=1883

# Reconnection interval to the MQTT Broker in seconds
AURA_RECONNECT_S=5

# IP/Hostname of the Host Hardware Daemon (accessed from inside the container)
# Usually the Docker network gateway (default: 172.18.0.1)
AURA_HARDWARE_DAEMON_HOST=172.17.0.1

# ── Runtime & Performance Loops ───────────────────────────────────────────────
# Frequency of telemetry status reports in seconds
AURA_TELEMETRY_INTERVAL=10

# Frequency of the inference/capture loop in seconds
AURA_INFERENCE_INTERVAL=0.1

# ── Logging & Storage ─────────────────────────────────────────────────────────
# Log output level: DEBUG, INFO, WARNING, ERROR
AURA_LOG_LEVEL=INFO

# Local working directory inside the container for storing compiled models/temp files
AURA_WORK_DIR=/tmp/aura
