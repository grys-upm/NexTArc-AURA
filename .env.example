# =============================================================================
# AURA Platform — Environment Variables
# Copia a .env y ajusta. NUNCA commitear.
# =============================================================================

COMPOSE_PROJECT_NAME=aura

ENV=development

# --- Secrets -----------------------------------------------------------------
SECRET_KEY=change-me-openssl-rand-hex-32-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTGRES_PASSWORD=aura_dev
MINIO_ROOT_PASSWORD=aura_dev

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=aura
POSTGRES_DB=aura

# --- MinIO -------------------------------------------------------------------
MINIO_ROOT_USER=aura
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_SCRIPTS=scripts
MINIO_BUCKET_COMPILED=compiled

# --- MQTT (anónimo en PoC) ---------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret

# --- Log level ---------------------------------------------------------------
LOG_LEVEL=DEBUG

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379

